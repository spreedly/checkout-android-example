<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Header Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="40dp"
            app:cardBackgroundColor="#6366F1"
            app:cardElevation="8dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_payment"
                android:contentDescription="@string/payment_sdk"
                app:tint="@android:color/white" />

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/java_hosted_fields_demo"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/enter_your_payment_details"
            android:textSize="16sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="24dp"
            android:gravity="center" />

        <!-- Saved Payment Methods Section -->
        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/saved_cards_compose_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="16dp" />

        <!-- Main Card Container -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">

                <!-- Merchant mask toggle (outside hosted fields — iframe pattern) -->
                <androidx.compose.ui.platform.ComposeView
                    android:id="@+id/merchant_mask_toggle_compose_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" />

                <!-- Hosted Fields Compose View -->
                <androidx.compose.ui.platform.ComposeView
                    android:id="@+id/hosted_fields_compose_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp" />

        <!-- Token Display Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/token_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardCornerRadius="8dp"
            app:cardBackgroundColor="#F3F4F6"
            app:cardElevation="2dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_check_circle"
                        android:contentDescription="@string/success"
                        app:tint="#10B981" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/payment_token_generated"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#374151" />

                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="4dp"
                    app:cardBackgroundColor="@android:color/white"
                    app:cardElevation="0dp">

                    <TextView
                        android:id="@+id/token_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/token_placeholder"
                        android:textSize="14sp"
                        android:textColor="#1F2937"
                        android:fontFamily="monospace"
                        android:padding="12dp"
                        android:textIsSelectable="true" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Auth nonce is single-use. Tap below to re-fetch auth and tokenize again."
                    android:textSize="12sp"
                    android:textColor="#6B7280" />

                <Button
                    android:id="@+id/retokenize_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Retokenize"
                    android:backgroundTint="#6366F1" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <Space
            android:layout_width="match_parent"
            android:layout_height="32dp" />

        <!-- Info Section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_security"
                android:contentDescription="@string/secure"
                app:tint="#10B981" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/secure_tokenized_payments"
                android:textSize="12sp"
                android:textColor="#6B7280" />

        </LinearLayout>

        <!-- Recache UI ComposeView (invisible but required) -->
        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/recache_compose_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </LinearLayout>

</ScrollView> 