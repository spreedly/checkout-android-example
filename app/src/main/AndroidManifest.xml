<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SpreedlyExample"
        android:enableOnBackInvokedCallback="true"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.SpreedlyExample">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Traditional Java Activity with XML Layout -->
        <activity
            android:name="com.spreedly.example.TraditionalActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.SpreedlyExample" />

        <!-- Pure Java Activity with XML Layout -->
        <activity
            android:name="com.spreedly.example.JavaPaymentActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.SpreedlyExample" />

        <!-- Java Hosted Fields Demo Activity -->
        <activity
            android:name="com.spreedly.example.JavaHostedFieldsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.SpreedlyExample" />

        <!-- Java Offsite Payment Activity (optional: set enableJavaOffsitePayment=true to enable) -->
        <activity
            android:name="com.spreedly.example.JavaOffsitePaymentActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.SpreedlyExample" />

    </application>

</manifest>
